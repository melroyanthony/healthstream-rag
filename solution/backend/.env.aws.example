# HealthStream RAG — AWS Production Configuration
# Copy to .env to activate: cp .env.aws.example .env
# Or set these as Lambda environment variables via Terraform.

# --- Backend selection ---
VECTOR_BACKEND=s3vectors
LLM_BACKEND=bedrock
EMBEDDER_BACKEND=bedrock

# --- AWS ---
AWS_REGION=eu-west-1
S3_VECTORS_BUCKET=healthstream-demo-vectors-ACCOUNT_ID
S3_VECTORS_INDEX=healthstream

# --- Bedrock models ---
BEDROCK_LLM_MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# --- Auth (false = Cognito JWT validation) ---
MOCK_AUTH=false

# --- Debug ---
DEBUG=false

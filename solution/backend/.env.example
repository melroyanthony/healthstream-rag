# HealthStream RAG Configuration
# Copy to .env and fill in values

# Vector backend: chroma | s3vectors (opensearch planned, not yet implemented)
VECTOR_BACKEND=chroma

# LLM backend: anthropic | bedrock
LLM_BACKEND=anthropic

# Embedder backend: local | bedrock
EMBEDDER_BACKEND=local

# Anthropic API key (for local dev, leave blank for mock mode)
ANTHROPIC_API_KEY=

# AWS region (for production)
AWS_REGION=eu-west-1

# Authentication (true for local dev)
MOCK_AUTH=true

# ChromaDB persistence
CHROMA_PERSIST_DIRECTORY=./chroma_data

# Debug mode
DEBUG=true

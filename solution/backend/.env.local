# HealthStream RAG — Local Development Configuration
# Copy to .env to activate: cp .env.local .env

# --- Backend selection ---
VECTOR_BACKEND=chroma
LLM_BACKEND=anthropic
EMBEDDER_BACKEND=local

# --- Anthropic (leave blank for mock LLM responses) ---
ANTHROPIC_API_KEY=

# --- ChromaDB ---
CHROMA_PERSIST_DIRECTORY=./chroma_data

# --- Auth (mock: Bearer token value = patient_id) ---
MOCK_AUTH=true

# --- Debug ---
DEBUG=true
